---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/nav/Navbar.astro';
import Hero from '../components/hero/Hero.astro';
import StripBar from '../components/common/StripBar.astro';
import ProcessBar from '../components/common/ProcessBar.astro';
import SocialProof from '../components/proof/SocialProof.astro';
import ReservationForm from '../components/reservation/ReservationForm.astro';
import LocationSection from '../components/location/LocationSection.astro';
import Footer from '../components/common/Footer.astro';
import WhatsAppFab from '../components/common/WhatsAppFab.astro';
import MenuOverlay from '../components/menu/MenuOverlay.astro';
import ProductSheet from '../components/menu/ProductSheet.astro';
import Cart from '../components/cart/Cart.astro';
import OffHoursModal from '../components/common/OffHoursModal.astro';
---

<BaseLayout>
  <Navbar />
  <main>
    <Hero />
    <StripBar />
    <ProcessBar />
    <SocialProof />
    <!-- Menu es overlay, no sección de flujo -->
    <ReservationForm />
    <LocationSection />
  </main>
  <Footer />

  <WhatsAppFab />

  <!-- Overlays -->
  <MenuOverlay />
  <ProductSheet />
  <Cart />
  <OffHoursModal />
</BaseLayout>
