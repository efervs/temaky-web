---
const year = new Date().getFullYear();
---
<footer class="bg-black border-t border-white/[.05] px-[5%] pt-11 pb-7">
  <div class="max-w-[1100px] mx-auto">

    <!-- 3-column grid -->
    <div class="grid grid-cols-3 max-[680px]:grid-cols-1 gap-[26px] pb-[26px] border-b border-white/[.05] mb-5">

      <!-- Col 1: Logo + tagline + socials -->
      <div>
        <img src="/images/logo/logo-temaky-sm.webp" alt="Temaky Sushi" width="120" height="44" class="h-[44px] w-auto block mb-[3px]" />
        <span class="text-[.78rem] text-white/55 block mb-[13px]">Sushi desde 1999 · Monterrey, N.L.</span>
        <div class="flex gap-[7px]">
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/temakysushimty/"
            target="_blank"
            rel="noopener"
            aria-label="Instagram"
            class="w-[36px] h-[36px] border border-white/[.11] rounded-[6px] flex items-center justify-center text-white/[.44] no-underline transition-colors hover:border-[#B8102E] hover:text-white"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <!-- Facebook -->
          <a
            href="#"
            aria-label="Facebook"
            class="w-[36px] h-[36px] border border-white/[.11] rounded-[6px] flex items-center justify-center text-white/[.44] no-underline transition-colors hover:border-[#B8102E] hover:text-white"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Navegación -->
      <div>
        <span class="text-[.82rem] font-semibold tracking-[.01em] text-white/70 block mb-[9px]">Navegación</span>
        <ul class="list-none space-y-0">
          <li><a href="#top" class="text-[.81rem] text-white/55 no-underline py-[6px] min-h-[44px] flex items-center hover:text-white transition-colors">Inicio</a></li>
          <li><a href="#" onclick="window.dispatchEvent(new CustomEvent('temaky:open-menu'));return false" class="text-[.81rem] text-white/55 no-underline py-[6px] min-h-[44px] flex items-center hover:text-white transition-colors">Menú completo</a></li>
          <li><a href="#ubic" class="text-[.81rem] text-white/55 no-underline py-[6px] min-h-[44px] flex items-center hover:text-white transition-colors">Ubicación</a></li>
          <li><a href="https://wa.me/528127474440" target="_blank" rel="noopener" class="text-[.81rem] text-white/55 no-underline py-[6px] min-h-[44px] flex items-center hover:text-white transition-colors">Contacto</a></li>
          <li><a href="tel:+528183462758" class="text-[.81rem] text-white/55 no-underline py-[6px] min-h-[44px] flex items-center hover:text-white transition-colors">Llamar</a></li>
        </ul>
      </div>

      <!-- Col 3: Delivery -->
      <div>
        <span class="text-[.82rem] font-semibold tracking-[.01em] text-white/70 block mb-[9px]">Delivery</span>
        <div class="flex flex-col gap-[6px]">
          <a
            href="https://www.rappi.com.mx/restaurantes/1923215355-temaky-sushi"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-[7px] bg-white/[.04] border border-white/[.07] rounded-[8px] px-3 py-[9px] min-h-[44px] text-[.76rem] text-white/55 no-underline hover:border-white/20 transition-colors"
          >
            <span class="w-[7px] h-[7px] rounded-full bg-[#FF441F] shrink-0"></span>Rappi
          </a>
          <a
            href="https://web.didiglobal.com/mx/food/monterrey-nle/temaky-sushi/5764607773783097417/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-[7px] bg-white/[.04] border border-white/[.07] rounded-[8px] px-3 py-[9px] min-h-[44px] text-[.76rem] text-white/55 no-underline hover:border-white/20 transition-colors"
          >
            <span class="w-[7px] h-[7px] rounded-full bg-[#FF7900] shrink-0"></span>DiDi Food
          </a>
          <a
            href="https://www.ubereats.com/mx/store/temaky-sushi/OqwiFbwtQea62BGRTsG1Ag"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-[7px] bg-white/[.04] border border-white/[.07] rounded-[8px] px-3 py-[9px] min-h-[44px] text-[.76rem] text-white/55 no-underline hover:border-white/20 transition-colors"
          >
            <span class="w-[7px] h-[7px] rounded-full bg-[#06C167] shrink-0"></span>UberEats
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <p class="text-[.72rem] text-white/65 flex justify-between flex-wrap gap-[5px] max-[680px]:flex-col">
      <span>© {year} Temaky Sushi. Todos los derechos reservados.</span>
      <span>Monterrey, Nuevo León, México</span>
    </p>

  </div>
</footer>
