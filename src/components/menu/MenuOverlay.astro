---
import { MENU, CATS, CAT_LBL, ORDERED_CATS, BUNDLE_CATS } from '../../data/menu';
import ProductCard from './ProductCard.astro';

const bundleSet = new Set<string>(BUNDLE_CATS as readonly string[]);
const groups = ORDERED_CATS.map(cat => ({
  cat,
  label: CAT_LBL[cat] ?? cat,
  promo: bundleSet.has(cat)
    ? (cat.startsWith('sig') ? '2×$229' : '2×$199')
    : null,
  items: MENU.filter(i => i.cat === cat),
}));
---

<div
  id="menu-overlay"
  class="menu-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Menú Temaky Sushi"
  aria-hidden="true"
  hidden
>
  <header class="m-hdr">
    <h2 class="m-title">Menú</h2>
    <div class="m-search">
      <svg class="si" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <path d="m20 20-3.5-3.5" />
      </svg>
      <input
        id="menu-search"
        type="search"
        placeholder="Buscar rollo, platillo…"
        aria-label="Buscar en el menú"
        autocomplete="off"
      />
    </div>
    <button class="m-x" id="menu-close" aria-label="Cerrar menú" type="button">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </header>

  <nav class="m-cats" id="menu-cats" aria-label="Categorías">
    {CATS.map(c => (
      <button
        class={`chip${c.id === 'all' ? ' on' : ''}`}
        data-cat={c.id}
        type="button"
        aria-pressed={c.id === 'all' ? 'true' : 'false'}
      >{c.lbl}</button>
    ))}
  </nav>

  <main class="m-body" id="menu-body">
    {groups.map(g => (
      <section class="cg" data-cat-group={g.cat}>
        <div class="cg-hdr">
          <span class="cg-title">{g.label}</span>
          <span class="cg-rule"></span>
          {g.promo ? <span class="cg-promo">Promo {g.promo}</span> : <span class="cg-count">{String(g.items.length).padStart(2, '0')}</span>}
        </div>
        <div class="grid">
          {g.items.map(item => <ProductCard item={item} />)}
        </div>
      </section>
    ))}
    <div class="no-res" id="menu-no-res" hidden>
      <span class="no-res-ico">🔍</span>
      Sin resultados
    </div>
    <span
      id="menu-sr-live"
      role="status"
      aria-live="polite"
      aria-atomic="true"
      style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0"
    ></span>
  </main>
</div>

<style>
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: var(--negro);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s ease;
  }
  .menu-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
  .menu-overlay[hidden] {
    display: none;
  }

  .m-hdr {
    position: sticky;
    top: 0;
    z-index: 4;
    height: 60px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 16px;
    background: rgba(0,0,0,0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--g06);
  }
  .m-title {
    font-family: var(--madec);
    font-size: 1.25rem;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: #fff;
    flex-shrink: 0;
    font-weight: 700;
    margin: 0;
  }
  .m-search {
    flex: 1;
    position: relative;
    max-width: 420px;
  }
  .m-search .si {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255,255,255,0.4);
    pointer-events: none;
    width: 16px;
    height: 16px;
  }
  .m-search input {
    width: 100%;
    height: 40px;
    background: var(--g06);
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0 14px 0 38px;
    font-size: .88rem;
    color: #fff;
    transition: background .2s ease, border-color .2s ease;
    font-family: var(--sans);
  }
  .m-search input::placeholder { color: rgba(255,255,255,0.4); }
  .m-search input:focus {
    background: var(--g10);
    border-color: var(--g10);
    outline: none;
  }
  .m-search input:focus-visible {
    outline: 2px solid rgba(184,16,46,0.8);
    outline-offset: -2px;
  }
  .m-x {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--g06);
    display: grid;
    place-items: center;
    border: 0;
    color: #fff;
    cursor: pointer;
    transition: background .2s ease;
  }
  .m-x:hover { background: var(--g10); }
  .m-x:focus-visible { outline: 2px solid var(--rojo); outline-offset: 2px; }
  .m-x svg { width: 14px; height: 14px; stroke: #fff; stroke-width: 2; fill: none; }

  .m-cats {
    position: sticky;
    top: 60px;
    z-index: 3;
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding: 12px 16px;
    flex-shrink: 0;
    background: rgba(0,0,0,0.94);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--g04);
    scrollbar-width: none;
  }
  .m-cats::-webkit-scrollbar { display: none; }
  .chip {
    flex-shrink: 0;
    min-height: 36px;
    padding: 0 16px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border-radius: 999px;
    background: var(--g06);
    color: var(--g55);
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .01em;
    white-space: nowrap;
    border: 0;
    cursor: pointer;
    font-family: var(--sans);
    transition: background .15s ease, color .15s ease;
  }
  .chip:hover { color: #fff; background: var(--g10); }
  .chip.on { background: var(--rojo); color: #fff; }
  .chip:focus-visible { outline: 2px solid var(--rojo); outline-offset: 2px; }

  .m-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px 16px 120px;
    -webkit-overflow-scrolling: touch;
  }

  .cg { margin-bottom: 8px; }
  .cg[hidden] { display: none; }
  .cg-hdr {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 14px;
  }
  .cg-title {
    font-family: var(--madec);
    font-size: .95rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    font-weight: 700;
  }
  .cg-rule {
    flex: 1;
    height: 1px;
    background: var(--g06);
  }
  .cg-count {
    font-size: .72rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: .05em;
  }
  .cg-promo {
    font-size: .66rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #1a0a00;
    background: var(--amarillo);
    padding: 3px 8px;
    border-radius: 999px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    margin-bottom: 26px;
  }
  :global(.pcard[hidden]) { display: none; }

  @media (min-width: 768px) {
    .grid { grid-template-columns: repeat(3, 1fr); gap: 12px; }
  }
  @media (min-width: 1200px) {
    .grid { grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .m-body { padding: 24px 28px 140px; }
    .m-hdr { padding: 0 28px; }
    .m-cats { padding: 14px 28px; }
  }

  .no-res {
    padding: 60px 20px;
    text-align: center;
    color: rgba(255,255,255,0.45);
    font-size: .9rem;
  }
  .no-res-ico {
    display: block;
    font-size: 2.4rem;
    margin-bottom: 10px;
  }
</style>

<script>
  import { trapFocus } from '../../lib/focus-trap';

  const overlay = document.getElementById('menu-overlay') as HTMLElement | null;
  if (overlay) {
    const body = document.getElementById('menu-body') as HTMLElement;
    const catsBar = document.getElementById('menu-cats') as HTMLElement;
    const searchInput = document.getElementById('menu-search') as HTMLInputElement;
    const closeBtn = document.getElementById('menu-close') as HTMLButtonElement;
    const noRes = document.getElementById('menu-no-res') as HTMLElement;
    const srLive = document.getElementById('menu-sr-live') as HTMLElement;

    let currentCat = 'all';
    let currentQuery = '';
    let lastFocus: HTMLElement | null = null;
    let releaseTrap: (() => void) | null = null;

    function openMenu() {
      lastFocus = document.activeElement as HTMLElement | null;
      overlay!.hidden = false;
      requestAnimationFrame(() => {
        overlay!.classList.add('open');
        searchInput.focus();
        releaseTrap?.();
        releaseTrap = trapFocus(overlay!);
      });
      overlay!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      overlay!.classList.remove('open');
      overlay!.setAttribute('aria-hidden', 'true');
      releaseTrap?.();
      releaseTrap = null;
      const restoreTo = lastFocus;
      lastFocus = null;
      setTimeout(() => {
        overlay!.hidden = true;
        restoreTo?.focus();
      }, 250);
      document.body.style.overflow = '';
    }

    function applyFilter() {
      const cards = body.querySelectorAll<HTMLElement>('.pcard');
      const groups = body.querySelectorAll<HTMLElement>('[data-cat-group]');
      const q = currentQuery;
      let anyVisible = false;

      cards.forEach(card => {
        const cat = card.dataset.cat ?? '';
        const blob = card.dataset.search ?? '';
        const catMatch = currentCat === 'all' || cat === currentCat;
        const searchMatch = !q || blob.includes(q);
        const visible = catMatch && searchMatch;
        card.hidden = !visible;
        if (visible) anyVisible = true;
      });

      groups.forEach(g => {
        const visibleInGroup = g.querySelectorAll<HTMLElement>('.pcard:not([hidden])').length;
        g.hidden = visibleInGroup === 0;
      });

      noRes.hidden = anyVisible;

      if (srLive) {
        const count = body.querySelectorAll<HTMLElement>('.pcard:not([hidden])').length;
        srLive.textContent = anyVisible
          ? `${count} resultado${count !== 1 ? 's' : ''}`
          : 'Sin resultados';
      }
    }

    catsBar.addEventListener('click', e => {
      const target = e.target as HTMLElement;
      const btn = target.closest<HTMLButtonElement>('.chip');
      if (!btn) return;
      catsBar.querySelectorAll<HTMLElement>('.chip').forEach(c => {
        c.classList.remove('on');
        c.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('on');
      btn.setAttribute('aria-pressed', 'true');
      currentCat = btn.dataset.cat ?? 'all';
      applyFilter();
      body.scrollTo({ top: 0, behavior: 'auto' });
    });

    searchInput.addEventListener('input', () => {
      currentQuery = searchInput.value.trim().toLowerCase();
      applyFilter();
    });

    closeBtn.addEventListener('click', closeMenu);

    body.addEventListener('click', e => {
      const target = e.target as HTMLElement;
      const card = target.closest<HTMLElement>('.pcard');
      if (!card) return;
      const id = card.dataset.id;
      if (!id) return;
      window.dispatchEvent(new CustomEvent('temaky:open-sheet', { detail: id }));
    });

    window.addEventListener('temaky:open-menu', openMenu);
    window.addEventListener('temaky:close-menu', closeMenu);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && !overlay!.hidden) closeMenu();
    });
  }
</script>
