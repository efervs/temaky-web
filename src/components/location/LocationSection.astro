---
---
<section class="bg-black py-[80px] px-6 md:px-[8%]" id="ubic">
  <div class="max-w-[1180px] mx-auto">

    <!-- Header fuera del grid para evitar overflow -->
    <div class="mb-10 md:mb-14 text-center max-w-[760px] mx-auto">
      <p class="text-[.78rem] font-semibold tracking-[.02em] text-white/60 mb-3">
        Dónde encontrarnos
      </p>
      <h2 class="font-['MADEC','Oswald','Bebas_Neue',Impact,sans-serif] font-bold leading-[.92] uppercase">
        <span class="text-white block text-[clamp(2rem,4.2vw,3.4rem)]">Encuéntranos</span>
        <span class="text-[#B8102E] block text-[clamp(2rem,4.2vw,3.4rem)]">en Obispado.</span>
      </h2>
    </div>

    <div class="grid grid-cols-2 max-[820px]:grid-cols-1 gap-9 items-start">

      <!-- Left card -->
      <div>
        <div class="bg-white/[.04] border border-white/[.07] rounded-[14px] p-[26px]">
          <!-- Address -->
          <div class="flex items-center gap-2 text-[.78rem] font-semibold tracking-[.01em] text-white/60 mb-[6px]">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2C8 2 5 5 5 9c0 5 7 13 7 13s7-8 7-13c0-4-3-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            Dirección
          </div>
          <span class="font-['MADEC','Oswald','Bebas_Neue',Impact,sans-serif] text-[1.02rem] uppercase block mb-[2px]">Plaza Villa Obispado</span>
          <span class="text-[.84rem] text-white/55 leading-[1.5]">
            Francisco Garza Sada 2940A · Piso 2, Local 204<br>
            Nuevo Obispado · Monterrey, N.L.
          </span>
          <a
            href="https://maps.app.goo.gl/gZdvYsTJmWGkcaNL6"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center min-h-[44px] text-[#E8304A] text-[.78rem] no-underline mt-[9px] hover:underline"
          >Abrir en Google Maps →</a>

          <div class="h-px bg-white/[.07] my-4"></div>

          <!-- Hours -->
          <div class="flex items-center gap-2 text-[.78rem] font-semibold tracking-[.01em] text-white/60 mb-[6px]">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
            Horario
          </div>
          <span class="font-['Cormorant_Garamond'] italic text-[1.65rem] block leading-none">12:00 – 22:00 hrs</span>
          <span class="text-[.75rem] text-white/55 mt-[2px] block">Lunes a Sábado · 12:00–22:00</span>

          <div class="h-px bg-white/[.07] my-4"></div>

          <!-- WhatsApp CTA -->
          <a
            href="https://wa.me/528127474440?text=Hola!%20Quiero%20hacer%20un%20pedido"
            target="_blank"
            rel="noopener"
            class="flex items-center justify-center gap-[9px] bg-[#25D366] text-[#0a2e1a] no-underline px-3 py-3 rounded-[8px] text-[.88rem] font-semibold mt-[14px] transition-colors hover:bg-[#1eae56] min-h-[44px]"
            style="color: #0a2e1a"
          >
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Pedir · +52 81 2747-4440
          </a>
        </div>
      </div>

      <!-- Right: Google Maps iframe (lazy-loaded, no JS required) -->
      <div class="rounded-[14px] overflow-hidden h-[420px] max-[820px]:h-[280px] border border-white/[.07] bg-[#111]">
        <iframe
          src="https://maps.google.com/maps?q=Temaky+Sushi,+Francisco+Garza+Sada+2940,+Nuevo+Obispado,+Monterrey,+NL,+Mexico&t=&z=16&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="100%"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Temaky Sushi en Google Maps"
          class="block border-0 rounded-[14px]"
        ></iframe>
      </div>

    </div>
  </div>
</section>
