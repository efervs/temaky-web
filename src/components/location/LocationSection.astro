---
---
<section class="bg-black py-[60px] px-[5%]" id="ubic">
  <div class="max-w-[1100px] mx-auto grid grid-cols-2 max-[820px]:grid-cols-1 gap-9 items-start">

    <!-- Left card -->
    <div>
      <p class="text-[.66rem] font-semibold tracking-[.28em] uppercase text-white/60 mb-[7px]">Dónde encontrarnos</p>
      <h2 class="font-['MADEC','Oswald','Bebas_Neue',Impact,sans-serif] font-bold leading-[.9] uppercase mb-[22px]">
        <span class="text-white block text-[clamp(2rem,4vw,3.3rem)]">Encuéntranos</span>
        <span class="text-[#B8102E] block text-[clamp(2rem,4vw,3.3rem)]">en Obispado.</span>
      </h2>

      <div class="bg-white/[.04] border border-white/[.07] rounded-[14px] p-[26px]">
        <!-- Address -->
        <div class="text-[.64rem] font-semibold uppercase tracking-[.17em] text-white/60 mb-[6px]">📍 Dirección</div>
        <span class="font-['MADEC','Oswald','Bebas_Neue',Impact,sans-serif] text-[1.02rem] uppercase block mb-[2px]">Plaza Villa Obispado</span>
        <span class="text-[.84rem] text-white/55 leading-[1.5]">
          Francisco Garza Sada 2940A · Piso 2, Local 204<br>
          Nuevo Obispado · Monterrey, N.L.
        </span>
        <a
          href="https://maps.app.goo.gl/gZdvYsTJmWGkcaNL6"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center min-h-[44px] text-[#E8304A] text-[.78rem] no-underline mt-[9px] hover:underline"
        >Abrir en Google Maps →</a>

        <div class="h-px bg-white/[.07] my-4"></div>

        <!-- Hours -->
        <div class="text-[.64rem] font-semibold uppercase tracking-[.17em] text-white/60 mb-[6px]">🕐 Horario</div>
        <span class="font-['Cormorant_Garamond'] italic text-[1.65rem] block leading-none">12:00 – 22:00 hrs</span>
        <span class="text-[.75rem] text-white/55 mt-[2px] block">Lunes a Sábado · 12:00–22:00</span>

        <div class="h-px bg-white/[.07] my-4"></div>

        <!-- WhatsApp CTA -->
        <a
          href="https://wa.me/528127474440?text=Hola!%20Quiero%20hacer%20un%20pedido%20🍣"
          target="_blank"
          rel="noopener"
          class="flex items-center justify-center gap-[9px] bg-[#25D366] text-white no-underline px-3 py-3 rounded-[8px] text-[.88rem] font-semibold mt-[14px] transition-colors hover:bg-[#1eae56] min-h-[44px]"
        >
          <!-- WhatsApp icon -->
          <svg width="17" height="17" viewBox="0 0 24 24" fill="white">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Pedir · +52 81 2747-4440
        </a>

        <!-- Delivery badges -->
        <div class="flex gap-[7px] mt-[11px] flex-wrap">
          <a
            href="https://www.rappi.com.mx/restaurantes/1923215355-temaky-sushi"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-[7px] bg-white/[.04] border border-white/[.07] rounded-[8px] px-3 py-[9px] min-h-[44px] text-[.76rem] text-white/55 no-underline hover:border-white/20 transition-colors"
          >
            <span class="w-[7px] h-[7px] rounded-full bg-[#FF441F] shrink-0"></span>Rappi
          </a>
          <a
            href="https://www.ubereats.com/mx/store/temaky-sushi/OqwiFbwtQea62BGRTsG1Ag"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-[7px] bg-white/[.04] border border-white/[.07] rounded-[8px] px-3 py-[9px] min-h-[44px] text-[.76rem] text-white/55 no-underline hover:border-white/20 transition-colors"
          >
            <span class="w-[7px] h-[7px] rounded-full bg-[#06C167] shrink-0"></span>UberEats
          </a>
          <a
            href="https://web.didiglobal.com/mx/food/monterrey-nle/temaky-sushi/5764607773783097417/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-[7px] bg-white/[.04] border border-white/[.07] rounded-[8px] px-3 py-[9px] min-h-[44px] text-[.76rem] text-white/55 no-underline hover:border-white/20 transition-colors"
          >
            <span class="w-[7px] h-[7px] rounded-full bg-[#FF7900] shrink-0"></span>DiDi Food
          </a>
        </div>
      </div>
    </div>

    <!-- Right: Google Maps iframe -->
    <div class="rounded-[14px] overflow-hidden h-[360px] max-[820px]:h-[250px]">
      <iframe
        src="https://maps.google.com/maps?q=Temaky+Sushi,+Francisco+Garza+Sada+2940,+Nuevo+Obispado,+Monterrey,+NL,+Mexico&t=&z=16&ie=UTF8&iwloc=&output=embed"
        width="100%"
        height="100%"
        style="border:0;display:block;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Temaky Sushi en Google Maps"
      ></iframe>
    </div>

  </div>
</section>
